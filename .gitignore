## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
!**/packages/repositories.config

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-*.xml

# xUnit
TestResults/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Backup & report files
*.tlog
*.log
*.bak
*.tmp
*.temp
*.dbmdl

# Local history
.localhistory/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
