{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "notification-worker-group",
    "Topics": {
      "NotificationRequest": "notification.request",
      "NotificationEmail": "notification.email",
      "NotificationSms": "notification.sms",
      "NotificationPush": "notification.push"
    }
  },
  "ChannelRouting": {
    "EventChannelMappings": {
      "ordencompletada": [ "Email", "Push" ],
      "alertainiciosesion": [ "Push", "Email" ],
      "promocionmundialfutbol": [ "SMS" ]
    }
  },
  "EmailTemplates": {
    "TemplatesRootPath": "Templates/Email",
    "EventTemplateMappings": {
      "ordencompletada": "OrdenCompletada",
      "alertainiciosesion": "AlertaInicioSesion"
    }
  },
  "PushRouting": {
    "DefaultAppId": "app-intelaf",
    "EventAppMappings": {
      "ordencompletada": "app-intelaf",
      "alertainiciosesion": "app-seguridad"
    },
    "FirebaseApps": {
      "app-intelaf": {
        "CredentialsSource": "File",
        "CredentialsLocation": "Credentials/firebase-intelaf.json"
      },
      "app-seguridad": {
        "CredentialsSource": "File",
        "CredentialsLocation": "Credentials/firebase-seguridad.json"
      }
    }
  }
}
